{
  "name": "nextdoor-cs",
  "version": "0.1.0",
  "description": "AI PC hardware and software diagnosis MVP",
  "author": "NextDoor CS",
  "private": true,
  "main": "dist/electron/main.js",
  "scripts": {
    "pwa:dev": "vite --mode pwa --port 3000",
    "pwa:build": "vite build --mode pwa",
    "pwa:preview": "vite preview",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "tsc -p tsconfig.electron.json && concurrently -k -n VITE,TSC,ELECTRON \"vite --mode electron --port 3000\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build --mode electron && tsc -p tsconfig.electron.json && electron-builder",
    "backend:dev": "cd backend && mvnw.cmd spring-boot:run",
    "backend:dev:env": "node scripts/run-backend-dev.mjs",
    "backend:dev:node": "node scripts/dev-gemini-guide-server.mjs",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:cv": "vitest run src/lib/cv",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "screenshot": "node scripts/screenshot.mjs"
  },
  "dependencies": {
    "@stomp/stompjs": "^7.0.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-qr-code": "^2.0.15",
    "sockjs-client": "^1.6.1",
    "systeminformation": "^5.22.11",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sockjs-client": "^1.5.4",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^30.0.6",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.0.1",
    "playwright": "^1.60.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^4.1.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.nextdoorcs.app",
    "productName": "옆집 컴공생",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/electron/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icons/icon-256.png",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icons/icon-256.png"
    }
  }
}
