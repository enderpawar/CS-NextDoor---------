# Vercel project environment variables
#
# Set these in Vercel Dashboard > Project > Settings > Environment Variables.
# Preview/Production can use different values.

# Backend API base URL. Vercel hosts only the PWA frontend in this project.
# Render blueprint default:
VITE_API_BASE_URL=https://nextdoor-cs-api.onrender.com

# Keep false when a deployed backend is available.
VITE_USE_MOCK=false
